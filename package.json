{
	"name": "rsseeder",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/inject-scheduled.js",
		"preview": "wrangler dev",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply rsseeder-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply rsseeder-db --remote",
		"db:seed": "wrangler d1 execute rsseeder-db --local --file=scripts/seed.sql",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "bun run build && bun run db:migrate:remote && wrangler deploy"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260317.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@unocss/preset-icons": "^66.6.7",
		"@unocss/preset-typography": "^66.6.7",
		"@unocss/preset-uno": "^66.6.7",
		"@unocss/reset": "^66.6.7",
		"@unocss/transformer-directives": "^66.6.7",
		"@unocss/vite": "^66.6.7",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"unocss": "^66.6.7",
		"vite": "^7.3.1",
		"wrangler": "^4.76.0"
	},
	"dependencies": {
		"arctic": "^3.7.0",
		"drizzle-orm": "^0.45.1",
		"fast-xml-parser": "^5.5.8",
		"katex": "^0.16.40",
		"lucide-svelte": "^0.577.0",
		"rehype-katex": "^7.0.1",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5"
	}
}
